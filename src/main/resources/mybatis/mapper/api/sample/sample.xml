<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.showcle.api.sample.mapper.SampleMapper">
   <select id="findAll" resultType="com.showcle.api.sample.dto.Sample">
        select * from sample
   </select>

    <insert id="insert" parameterType="com.showcle.api.sample.dto.Sample">
        insert into sample (name, bool, date, created_at, updated_at) values (#{name}, #{bool}, now(), now(), now())
    </insert>

    <update id="update" parameterType="com.showcle.api.sample.dto.Sample">
        update sample
           set name = #{name}
             , bool = #{bool}
             , date = #{date}
             , updated_at = now()
         where idx = #{idx}
    </update>

    <delete id="deleteAll">
        delete from sample
    </delete>
</mapper>